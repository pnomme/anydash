# OIDC example env.
# For provider-specific presets, prefer:
#   .env.oidc.keycloak.example
#   .env.oidc.authentik.example
#
# Quick validation:
#   npm run oidc:doctor

NODE_ENV=development
PORT=8000

# Allowed frontend origin(s) (comma-separated).
# Repo frontend dev default is 6767.
FRONTEND_URL=http://localhost:6767

AUTH_MODE=hybrid

OIDC_PROVIDER_NAME=Keycloak
OIDC_ISSUER_URL=http://localhost:8080/realms/anydash
OIDC_CLIENT_ID=anydash

# Redirect URI must match the frontend you're using.
OIDC_REDIRECT_URI=http://localhost:6767/api/auth/oidc/callback

# Optional, but recommended if you restart the backend often and want stable cookies.
# JWT_SECRET=change-me-to-a-long-random-string
# CSRF_SECRET=change-me-to-a-long-random-string
