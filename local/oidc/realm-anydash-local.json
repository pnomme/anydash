      "webOrigins": [
        "http://localhost:1002",
        "http://localhost:1003",
        "http://localhost:5173",
        "http://localhost:6767"
      ]
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "email": "alice@example.com",
      "firstName": "Alice",
      "lastName": "Example",
      "credentials": [
        {
          "type": "password",
          "value": "alicepass",
          "temporary": false
        }
      ]
    }
  ]
